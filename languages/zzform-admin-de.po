msgstr "Ungültiges JSON."

#: behaviour/make-thumbnails.js
msgid "Init failed."
msgstr "Initialisierung fehlgeschlagen."

#: behaviour/make-thumbnails.js
msgid "Step failed."
msgstr "Schritt fehlgeschlagen."

#: templates/make-thumbnails.template.txt
msgid ""
"Here, you can create either missing thumbnails, if they were not created on "
"upload. Or you can create completely new thumbnails if you changed the pixel "
"size."
msgstr ""
"Hier können Sie entweder fehlende Vorschaubilder erstellen, falls diese "
"nicht beim Hochladen erstellt wurden. Oder Sie können komplett neue "
"Vorschaubilder erstellen, z. B. falls Sie die Bildgröße geändert haben."

#: templates/make-thumbnails.template.txt
msgid "Form"
msgstr "Formular"

#: templates/make-thumbnails.template.txt
msgid "Mode"
msgstr "Modus"

#: templates/make-thumbnails.template.txt
msgid "Overwrite (existing thumbnail files are replaced)."
msgstr "Überschreiben (vorhandene Vorschaubilddateien werden ersetzt)."

#: templates/make-thumbnails.template.txt
msgid "Only missing thumbnails."
msgstr "Nur fehlende Vorschaubilder."

#: templates/make-thumbnails.template.txt
msgid "Start thumbnail creation"
msgstr "Vorschaubilder erstellen"

#: templates/make-thumbnails.template.txt
msgid "Stop"
msgstr "Stopp"

#: templates/make-thumbnails.template.txt
msgid "Progress"
msgstr "Fortschritt"

