#: zzbrick_make/thumbnails.inc.php
msgid "Thumbnail creation"
msgstr "Erstellen von Vorschaubildern"

#: zzbrick_make/thumbnails.inc.php
msgid ""
"Here, you can create either missing thumbnails, if they were not created on "
"upload. Or you can create completely new thumbnails if you changed the pixel "
"size."
msgstr ""
"Hier können Sie entweder fehlende Vorschaubilder erstellen, falls diese "
"nicht beim Hochladen erstellt wurden. Oder Sie können komplett neue "
"Vorschaubilder erstellen, z. B. falls Sie die Bildgröße geändert haben."

#: zzbrick_make/thumbnails.inc.php
msgid "Sorry, but the table script %s could not be found."
msgstr ""
"Entschuldigung, aber das Tabellenskript %s konnte nicht gefunden werden."

#: zzbrick_make/thumbnails.inc.php
msgid "The original file does not exist."
msgstr "Die Originaldatei existiert nicht."

#: zzbrick_make/thumbnails.inc.php
msgid "The function %s does not exist."
msgstr "Die Funktion %s existiert nicht."

#: zzbrick_make/thumbnails.inc.php
msgid "Thumbnail for %s × %s px was created."
msgstr "Ja! Ein Vorschaubild für %s × %s px wurde erstellt."

#: zzbrick_make/thumbnails.inc.php
msgid "Thumbnail for %s × %s px could not be created."
msgstr "Nein. Ein Vorschaubild für %s × %s px konnte nicht erstellt werden."

#: zzbrick_make/thumbnails.inc.php
msgid "No missing thumbnails were found."
msgstr "Es wurden keine fehlenden Vorschaubilder gefunden."

#: zzbrick_make/thumbnails.inc.php
msgid "The original file does not contain any data."
msgstr "Die Originaldatei enthält keine Daten."
