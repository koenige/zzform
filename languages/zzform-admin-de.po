msgid "Thumbnail creation"
msgstr "Erstellen von Vorschaubildern"

#: zzbrick_make/thumbnails.inc.php
msgid "Invalid thumbnails request."
msgstr "Ungültige Anfrage für Vorschaubilder."

#: zzbrick_make/thumbnails.inc.php
msgid "Session expired or invalid. Please start again."
msgstr "Sitzung abgelaufen oder ungültig. Bitte erneut starten."

#: zzbrick_make/thumbnails.inc.php
msgid "Form script or mode does not match."
msgstr "Formularskript oder Modus passt nicht."

#: zzbrick_make/thumbnails.inc.php
msgid "Invalid processed count."
msgstr "Ungültige Anzahl verarbeiteter Einträge."

#: zzbrick_make/thumbnails.inc.php
msgid "Invalid thumbnails finalize request."
msgstr "Ungültige Abschluss-Anfrage für Vorschaubilder."

#: zzbrick_make/thumbnails.inc.php
msgid "Stopped after %d of %d."
msgstr "Gestoppt nach %d von %d."

#: zzbrick_make/thumbnails.inc.php
msgid "Finished with %d error (see log)."
msgid_plural "Finished with %d errors (see log)."
msgstr[0] "Abgeschlossen mit %d Fehler (siehe Protokoll)."
msgstr[1] "Abgeschlossen mit %d Fehlern (siehe Protokoll)."

#: zzbrick_make/thumbnails.inc.php
msgid "All thumbnails processed."
msgstr "Alle Vorschaubilder verarbeitet."

#: zzbrick_make/thumbnails.inc.php
